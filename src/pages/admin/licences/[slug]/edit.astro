---
import Layout from '../../../../layouts/Layout.astro';
import { getLicence, saveLicence, saveImage, deleteImage, slugify, type Movie, type Licence } from '../../../../lib/cms';

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/admin/licences');
}

const post = await getLicence(slug) as Licence;

if (!post) {
    return Astro.redirect('/admin/licences');
}

const method = Astro.request.method;

if (method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title')?.toString();

    const movieTitles = formData.getAll('movie_title');
    const movieSynopses = formData.getAll('movie_synopsis');
    const movieDates = formData.getAll('movie_releaseDate');
    const movieTrailers = formData.getAll('movie_trailerUrl');
    const movieImages = formData.getAll('movie_image'); // File objects or strings if no change
    const movieExistingImages = formData.getAll('movie_existing_image');

    const movies: Movie[] = [];

    for (let i = 0; i < movieTitles.length; i++) {
        const imageFile = movieImages[i] as File;
        let imageUrl = movieExistingImages[i]?.toString() || '';
        const movieTitle = movieTitles[i].toString();
        
        if (imageFile && imageFile.size > 0) {
            const buffer = Buffer.from(await imageFile.arrayBuffer());
            const extension = imageFile.name.split('.').pop() || 'jpg';
            const filename = `${slug}-${slugify(movieTitle)}.${extension}`;
            imageUrl = await saveImage(filename, buffer, import.meta.env.GITHUB_PAGES_IMAGES);
        }

        movies.push({
            title: movieTitle,
            synopsis: movieSynopses[i].toString(),
            releaseDate: movieDates[i].toString(),
            trailerUrl: movieTrailers[i]?.toString() || undefined,
            image: imageUrl
        });
    }

    if (title) {
        // Identifier les images à supprimer (celles qui étaient là, mais ne sont plus dans la nouvelle liste)
        const oldImages = post.movies?.map(m => m.image).filter(img => img) || [];
        const newImages = movies.map(m => m.image).filter(img => img);
        
        const imagesToDelete = oldImages.filter(img => !newImages.includes(img));
        
        for (const imgUrl of imagesToDelete) {
            await deleteImage(imgUrl, import.meta.env.GITHUB_PAGES_IMAGES);
        }

        await saveLicence({ slug, title, movies }, import.meta.env.GITHUB_PAGES_DATA);
        return Astro.redirect(`/admin/licences/${slug}`);
    }
  } catch (e) {
    console.error(e);
  }
}
---

<Layout>
    <div class="admin-header">
        <a href={`/admin/licences/${slug}`} class="back-link">← Annuler et retour</a>
        <h1>Modifier la licence</h1>
    </div>

    <section class="admin-section">
        <div class="card">
            <form method="POST" enctype="multipart/form-data" class="admin-form">
                <div class="form-group">
                    <label for="title">Titre de la licence</label>
                    <input type="text" id="title" name="title" value={post.title} required />
                </div>

                <div class="form-group">
                    <label for="slug-readonly">Slug (non modifiable)</label>
                    <input type="text" id="slug-readonly" value={slug} disabled class="input-disabled" />
                </div>

                <div class="movies-section">
                    <h2>Films</h2>
                    <div id="movies-container">
                        {post.movies?.map((movie, index) => (
                            <div class="movie-card">
                                <div class="movie-header">
                                    <h3>Film #{index + 1}</h3>
                                    <button type="button" class="remove-movie-btn">&times;</button>
                                </div>
                                <div class="movie-grid">
                                    <div class="form-group">
                                        <label for="movie_title">Titre du film</label>
                                        <input type="text" id="movie_title" name="movie_title" value={movie.title} required />
                                    </div>
                                    <div class="form-group">
                                        <label for="movie_releaseDate">Date de sortie</label>
                                        <input type="date" id="movie_releaseDate" name="movie_releaseDate" value={movie.releaseDate} required />
                                    </div>
                                    <div class="form-group">
                                        <label for="movie_trailerUrl">Bande annonce (URL optionnelle)</label>
                                        <input type="url" id="movie_trailerUrl" name="movie_trailerUrl" value={movie.trailerUrl} />
                                    </div>
                                    <div class="form-group">
                                        <label>Image du film (cliquer sur l'image pour modifier)</label>
                                        <div class="image-upload-wrapper">
                                            <input type="file" name="movie_image" accept="image/*" class="movie-image-input" id={`file-input-${index}`} />
                                            <label for={`file-input-${index}`} class="image-preview-label" tabindex="0" role="button" aria-label="Choisir une image pour le film">
                                                <div class="image-preview-container">
                                                    {movie.image && (
                                                        <div class="current-image">
                                                            <img src={movie.image} alt={movie.title} class="preview-img" />
                                                            <span class="image-url">{movie.image}</span>
                                                        </div>
                                                    )}
                                                    <div class="new-preview hidden">
                                                        <span>Aperçu :</span>
                                                        <img src="" alt="Preview" class="preview-img" />
                                                    </div>
                                                    {!movie.image && (
                                                        <div class="placeholder-preview">
                                                            <span class="plus-icon">+</span>
                                                            <span>Ajouter une image</span>
                                                        </div>
                                                    )}
                                                    <div class="upload-overlay">
                                                        <span>Changer l'image</span>
                                                    </div>
                                                </div>
                                            </label>
                                        </div>
                                        <input type="hidden" name="movie_existing_image" value={movie.image} />
                                    </div>
                                    <div class="form-group full-width">
                                        <label for="movie_synopsis">Synopsis</label>
                                        <textarea id="movie_synopsis" name="movie_synopsis" rows="4" required>{movie.synopsis}</textarea>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                    <button type="button" id="add-movie-btn" class="btn btn-secondary">Ajouter un film</button>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
                    <a href={`/admin/licences/${slug}`} class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </section>

    <template id="movie-template">
        <div class="movie-card">
            <div class="movie-header">
                <h3>Nouveau film</h3>
                <button type="button" class="remove-movie-btn">&times;</button>
            </div>
            <div class="movie-grid">
                <div class="form-group">
                    <label for="movie_title">Titre du film</label>
                    <input type="text" id="movie_title" name="movie_title" required />
                </div>
                <div class="form-group">
                    <label for="movie_releaseDate">Date de sortie</label>
                    <input type="date" id="movie_releaseDate" name="movie_releaseDate" required />
                </div>
                <div class="form-group">
                    <label for="movie_trailerUrl">Bande annonce (URL optionnelle)</label>
                    <input type="url" id="movie_trailerUrl" name="movie_trailerUrl" />
                </div>
                <div class="form-group">
                    <label>Image du film</label>
                    <div class="image-upload-wrapper">
                        <input type="file" name="movie_image" accept="image/*" required class="movie-image-input" />
                        <label class="image-preview-label" tabindex="0" role="button" aria-label="Choisir une image pour le film">
                            <div class="image-preview-container">
                                <div class="new-preview hidden">
                                    <span>Aperçu :</span>
                                    <img src="" alt="Preview" class="preview-img" />
                                </div>
                                <div class="placeholder-preview">
                                    <span class="plus-icon">+</span>
                                    <span>Ajouter une image</span>
                                </div>
                                <div class="upload-overlay">
                                    <span>Changer l'image</span>
                                </div>
                            </div>
                        </label>
                    </div>
                    <input type="hidden" name="movie_existing_image" value="" />
                </div>
                <div class="form-group full-width">
                    <label for="movie_synopsis">Synopsis</label>
                    <textarea id="movie_synopsis" name="movie_synopsis" rows="4" required></textarea>
                </div>
            </div>
        </div>
    </template>
</Layout>

<script>
    const container = document.getElementById('movies-container');
    const addBtn = document.getElementById('add-movie-btn');
    const template = document.getElementById('movie-template') as HTMLTemplateElement;

    function handleImagePreview(input: HTMLInputElement) {
        const wrapper = input.closest('.image-upload-wrapper');
        const label = wrapper?.querySelector('.image-preview-label') as HTMLLabelElement;
        const container = wrapper?.querySelector('.image-preview-container');
        const newPreview = container?.querySelector('.new-preview');
        const placeholder = container?.querySelector('.placeholder-preview');
        const img = newPreview?.querySelector('img');

        input.addEventListener('change', () => {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    if (img && e.target?.result) {
                        img.src = e.target.result as string;
                        newPreview?.classList.remove('hidden');
                        placeholder?.classList.add('hidden');
                    }
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                newPreview?.classList.add('hidden');
                if (!wrapper?.querySelector('.current-image')) {
                    placeholder?.classList.remove('hidden');
                }
            }
        });

        // Accessibilité au clavier
        label?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                input.click();
            }
        });
    }

    function setupRemoveButtons() {
        document.querySelectorAll('.remove-movie-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                (e.target as HTMLElement).closest('.movie-card')?.remove();
            });
        });
    }

    function setupImagePreviews() {
        document.querySelectorAll('.movie-image-input').forEach(input => {
            handleImagePreview(input as HTMLInputElement);
        });
    }

    addBtn?.addEventListener('click', () => {
        const clone = template.content.cloneNode(true) as HTMLElement;
        const removeBtn = clone.querySelector('.remove-movie-btn');
        const imageInput = clone.querySelector('.movie-image-input') as HTMLInputElement;
        const label = clone.querySelector('.image-preview-label') as HTMLLabelElement;
        
        // Générer un ID unique pour le clone
        const uniqueId = `file-input-new-${Date.now()}`;
        if (imageInput && label) {
            imageInput.id = uniqueId;
            label.setAttribute('for', uniqueId);
            handleImagePreview(imageInput);
        }
        
        removeBtn?.addEventListener('click', (e) => {
            (e.target as HTMLElement).closest('.movie-card')?.remove();
        });

        container?.appendChild(clone);
    });

    setupRemoveButtons();
    setupImagePreviews();
</script>

<style>
    .admin-header {
        margin-bottom: 3rem;
    }

    .back-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 500;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .admin-header h1 {
        font-size: 2.5rem;
        background: linear-gradient(to right, #fff, var(--primary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .card {
        background: var(--card-bg);
        padding: 2.5rem;
        border-radius: 1.5rem;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);
    }

    .admin-form {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    label {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    input, textarea {
        padding: 1rem;
        background: #0f172a;
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: white;
        transition: all 0.2s;
    }

    input:focus, textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
    }

    .input-disabled {
        opacity: 0.6;
        cursor: not-allowed;
        background: rgba(15, 23, 42, 0.5);
    }

    .movies-section {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }

    .movies-section h2 {
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
    }

    .movie-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
        padding: 1.5rem;
        border-radius: 1rem;
        margin-bottom: 1.5rem;
    }

    .movie-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 0.75rem;
    }

    .movie-header h3 {
        font-size: 1.1rem;
        color: var(--primary);
    }

    .remove-movie-btn {
        background: none;
        border: none;
        color: #ef4444;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0;
        line-height: 1;
    }

    .movie-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    /* Nouveau style pour l'input file caché et l'image cliquable */
    .image-upload-wrapper {
        position: relative;
    }

    .movie-image-input {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }

    .image-preview-label {
        display: block;
        cursor: pointer;
        border-radius: 1rem;
        transition: all 0.2s;
        border: 2px solid var(--border);
        padding: 0.5rem;
        background: rgba(15, 23, 42, 0.3);
    }

    .image-preview-label:hover {
        border-color: var(--primary);
        background: rgba(99, 102, 241, 0.05);
    }

    .image-preview-label:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
    }

    .image-preview-container {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-height: 150px;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        border-radius: 0.5rem;
    }

    .upload-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        pointer-events: none;
        border-radius: 0.5rem;
    }

    .image-preview-label:hover .upload-overlay {
        opacity: 1;
    }

    .placeholder-preview {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
    }

    .plus-icon {
        font-size: 2rem;
        font-weight: 300;
    }

    .current-image {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        align-items: center;
        width: 100%;
    }

    .image-preview-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 0.75rem;
    }

    .preview-img {
        width: 100%;
        max-width: 200px;
        height: auto;
        border-radius: 0.5rem;
        border: 1px solid var(--border);
        object-fit: cover;
    }

    .new-preview {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--primary);
    }

    .image-url {
        word-break: break-all;
        font-family: monospace;
        opacity: 0.7;
    }

    .hidden {
        display: none;
    }

    @media (max-width: 768px) {
        .movie-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s;
        cursor: pointer;
        border: none;
        font-size: 1rem;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
    }

    .btn-primary:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        color: white;
        border: 1px solid var(--border);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
    }
</style>
