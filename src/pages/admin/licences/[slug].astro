---
import Layout from '../../../layouts/Layout.astro';
import { getLicence, deleteLicence } from '../../../lib/cms';

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/admin/licences');
}

const method = Astro.request.method;

if (method === 'POST') {
    await deleteLicence(slug, import.meta.env.GITHUB_PAGES_IMAGES);
    return Astro.redirect('/admin/licences');
}

const post = await getLicence(slug);

if (!post) {
    return Astro.redirect('/admin/licences');
}
---

<Layout>
    <div class="admin-header">
        <a href="/admin/licences" class="back-link">← Retour aux licences</a>
        <div class="header-content">
            <h1>{post.title}</h1>
            <div class="actions">
                <a href={`/admin/licences/${slug}/edit`} class="btn btn-primary">Modifier</a>
                <a href={`/api/licences/${slug}.json`} target="_blank" class="btn btn-secondary">Voir le JSON</a>
                <form method="POST" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette licence et toutes les images associées ? Cette action est irréversible.')">
                    <button type="submit" class="btn btn-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                        Supprimer la licence
                    </button>
                </form>
            </div>
        </div>
        <div class="meta">
            <span class="slug">/{post.slug}</span>
            <span class="date">📅 {new Date(post.date).toLocaleDateString('fr-FR', { dateStyle: 'long' })}</span>
        </div>
    </div>

    <section class="admin-section">
        {post.movies && post.movies.length > 0 ? (
            <div class="card movies-preview">
                <h2>Films ({post.movies.length})</h2>
                <div class="movies-grid">
                    {post.movies.map((movie: any) => (
                        <div class="movie-card">
                            <div class="movie-image">
                                {movie.image ? (
                                    <img src={movie.image} alt={movie.title} />
                                ) : (
                                    <div class="no-image">Pas d'image</div>
                                )}
                            </div>
                            <div class="movie-info">
                                <h3>{movie.title}</h3>
                                <p class="movie-date">📅 Sortie : {new Date(movie.releaseDate).toLocaleDateString('fr-FR')}</p>
                                <p class="movie-synopsis">{movie.synopsis}</p>
                                {movie.trailerUrl && (
                                    <a href={movie.trailerUrl} target="_blank" class="trailer-link">🎬 Bande annonce</a>
                                )}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        ) : (
            <div class="card no-movies">
                <p>Aucun film n'est associé à cette licence.</p>
                <div class="actions" style="margin-top: 1rem;">
                    <a href={`/admin/licences/${slug}/edit`} class="btn btn-primary">Ajouter des films</a>
                </div>
            </div>
        )}
    </section>
</Layout>

<style>
    /* ... existing styles ... */
    .movies-preview {
        margin-top: 2rem;
    }

    .movies-preview h2 {
        margin-bottom: 2rem;
        font-size: 1.5rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
    }

    .movies-grid {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .movie-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
        border-radius: 1rem;
        overflow: hidden;
        display: flex;
        flex-direction: row;
        align-items: stretch;
        max-width: 50%;
    }

    .movie-image {
        width: 200px;
        min-width: 200px;
        aspect-ratio: 2/3;
        background: #0f172a;
    }

    .movie-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .no-image {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .movie-info {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .movie-info h3 {
        margin-bottom: 0.5rem;
        color: var(--primary);
    }

    .movie-date {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    .movie-synopsis {
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        color: #cbd5e1;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .trailer-link {
        margin-top: auto;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
    }
    .admin-header {
        margin-bottom: 3rem;
    }

    .back-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 500;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .header-content h1 {
        font-size: 2.5rem;
        background: linear-gradient(to right, #fff, var(--primary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .actions {
        display: flex;
        gap: 1rem;
    }

    .meta {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        color: var(--text-muted);
    }

    .slug {
        font-family: ui-monospace, monospace;
        font-size: 1rem;
        color: var(--primary);
        background: rgba(99, 102, 241, 0.1);
        padding: 0.3rem 0.7rem;
        border-radius: 6px;
    }

    .card {
        background: var(--card-bg);
        padding: 2.5rem;
        border-radius: 1.5rem;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);
    }

    .content-preview h2 {
        margin-bottom: 2rem;
        font-size: 1.5rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
    }

    .content-body {
        line-height: 1.8;
        font-size: 1.1rem;
        color: #e2e8f0;
    }

    .content-body p {
        margin-bottom: 1.5rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.8rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        border: none;
        font-size: 0.95rem;
        gap: 0.5rem;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.2);
    }

    .btn-primary:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        color: white;
        border: 1px solid var(--border);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
    }

    .btn-danger {
        background: #ef4444;
        color: white;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.2);
    }

    .btn-danger:hover {
        background: #dc2626;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.4);
    }

    .btn-danger svg {
        transition: transform 0.3s ease;
    }

    .btn-danger:hover svg {
        transform: rotate(15deg) scale(1.1);
    }

    @media (max-width: 640px) {
        .movie-card {
            flex-direction: column;
        }
        .movie-image {
            width: 100%;
            aspect-ratio: 16/9;
        }
        .header-content {
            flex-direction: column;
            align-items: flex-start;
        }
        .actions {
            width: 100%;
        }
        .btn {
            flex: 1;
        }
    }
</style>
